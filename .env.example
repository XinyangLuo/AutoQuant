# Copy to .env and fill in your own values. Never commit .env.
# CLAUDE.md §2 is authoritative; this file is a quick-start scaffold.

# --- Tushare Pro (EOD data) ---------------------------------------------------
TUSHARE_TOKEN=

# --- DeepSeek LLM (Agent factor research) ------------------------------------
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com  # optional, for custom endpoints

# --- Push channels (signal delivery, future) ---------------------------------
WECHAT_WEBHOOK=
FEISHU_WEBHOOK=

# --- xtquant / QMT mini (realtime intraday, optional) -------------------------
# Only needed if you use backtest/data/realtime/xtquant_quote.
# Read-only market data does NOT require account credentials — only that the
# QMT client be running and logged in interactively. Account-bearing fields
# belong in trading/broker/ (Phase 2), not here.
QMT_PYTHON_PATH=
QMT_USERDATA_DIR=
